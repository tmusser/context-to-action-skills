{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decision Snapshot",
  "description": "Optional durable snapshot for choosing between options from messy context.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_scope",
    "decisions",
    "options",
    "evidence",
    "suggested_next_response"
  ],
  "properties": {
    "source_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sources_reviewed",
        "known_limitations",
        "source_gaps"
      ],
      "properties": {
        "sources_reviewed": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "known_limitations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_gaps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "text",
          "source_anchor",
          "confidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "source_anchor": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assumptions": {
